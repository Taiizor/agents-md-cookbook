{
  "name": "agents-md-cookbook",
  "version": "1.0.0",
  "private": true,
  "description": "The tested, tool-agnostic AGENTS.md kit.",
  "license": "MIT",
  "author": "Taiizor",
  "repository": {
    "type": "git",
    "url": "https://github.com/Taiizor/agents-md-cookbook.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#**/node_modules/**\" \"#**/CHANGELOG.md\" \"#docs/superpowers/**\" \"#packages/*/test/fixtures/**\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\" \"#**/node_modules/**\" \"#**/CHANGELOG.md\" \"#docs/superpowers/**\" \"#packages/*/test/fixtures/**\""
  },
  "devDependencies": {
    "markdownlint-cli2": "0.23.0"
  },
  "engines": {
    "node": ">=20"
  }
}
